<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:Meda="using:AndromedaDnsFirewall"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AndromedaDnsFirewall.TabLog"
			 >
	
	<ListBox 
		AutoScrollToSelectedItem="False"  
		Name="ge_logs"
		
	>

		<ListBox.Styles>
			<Style Selector="ListBoxItem">
				<!-- Привязываем фон контейнера к свойству Background из модели -->
				<Setter Property="Background" Value="{Binding Background}" />
			</Style>
		</ListBox.Styles>
		
		<ListBox.ContextMenu>
			<ContextMenu>
				<MenuItem Name="cmd_block" Header="Block" />
				<MenuItem Name="cmd_allow" Header="Allow" />
				<MenuItem Name="cmd_clear" Header="Clear" />
				<MenuItem Name="cmd_copy" Header="Copy" />
			</ContextMenu>
		</ListBox.ContextMenu>
		<ListBox.Styles>
			<Style Selector="ListBoxItem">
				<Setter Property="Padding" Value="0"/>
			</Style>
		
		</ListBox.Styles>
		<ListBox.ItemTemplate>
			<DataTemplate x:DataType="Meda:LogItem">
				<TextBlock   Text="{Binding}" FontSize="14" TextWrapping="NoWrap" />
			</DataTemplate>
		</ListBox.ItemTemplate>
	</ListBox>
	
</UserControl>
